# MongoDB metadata store. Use MONGO_URI or MONGODB_URI.
MONGO_URI=mongodb://localhost:27017
# MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/p2p_notes
MONGO_DB=p2p_notes

# Tracker server
TRACKER_HOST=127.0.0.1
TRACKER_PORT=8000
TRACKER_URL=http://127.0.0.1:8000
HEARTBEAT_TTL_SECONDS=30

# Current peer node. Change these for each peer terminal.
PEER_ID=peer1
PEER_NAME=Peer One
PEER_HOST=127.0.0.1
PEER_PORT=9001
PEER_STORAGE_DIR=./data/peer1
DOWNLOAD_DIR=./downloads
CHUNK_SIZE_BYTES=1048576
